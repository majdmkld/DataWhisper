@{
    ViewData["Title"] = "Home";
}

<section class="hero-section">
    <h1 class="animate-in">Welcome to Nexus Corp</h1>
    <p class="hero-subtitle animate-in">Your central hub for company resources, real-time analytics, and intelligent insights — powered by AI.</p>
    <hr class="hero-divider" />
</section>

<div class="portal-grid px-2 pb-5">
    <div class="card card-dark shadow-sm h-100 animate-in">
        <div class="card-body">
            <div class="card-icon card-icon-cyan">&#9632;</div>
            <h5 class="card-title">Dashboards</h5>
            <p class="card-text">Interactive Power BI dashboards and live analytics at your fingertips.</p>
            <a asp-action="Dashboards" class="btn btn-primary mt-2">Open Dashboards</a>
        </div>
    </div>
    <div class="card card-dark shadow-sm h-100 animate-in">
        <div class="card-body">
            <div class="card-icon card-icon-purple">&#9830;</div>
            <h5 class="card-title">Reports</h5>
            <p class="card-text">Company reports and performance metrics, generated on demand.</p>
            <a href="#" class="btn btn-outline-secondary mt-2">Coming Soon</a>
        </div>
    </div>
    <div class="card card-dark shadow-sm h-100 animate-in">
        <div class="card-body">
            <div class="card-icon card-icon-emerald">&#9679;</div>
            <h5 class="card-title">Team</h5>
            <p class="card-text">Team directory, org charts, and collaboration tools.</p>
            <a href="#" class="btn btn-outline-secondary mt-2">Coming Soon</a>
        </div>
    </div>
</div>
