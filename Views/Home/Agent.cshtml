@{
    ViewData["Title"] = "Data Agent";
}

<div class="page-title-area">
    <p class="subtitle">Powered by Azure AI Foundry</p>
    <h1>Data Agent</h1>
    <hr class="title-divider" />
</div>

<div class="agent-chat-fullpage" style="position:relative;z-index:1;">
    <div class="agent-chat-container">
        <!-- Messages area -->
        <div class="agent-messages" id="agentMessages">
            <div class="agent-welcome">
                <div class="agent-welcome-icon">&#9670;</div>
                <h3>Router Agent</h3>
                <p>Ask anything about HR or Sales — the router will direct your query to the right specialist agent.</p>
                <div class="agent-suggestions" id="agentSuggestions">
                    <button class="agent-suggestion-chip" data-prompt="How many employees are in the Engineering department?">How many employees are in Engineering?</button>
                    <button class="agent-suggestion-chip" data-prompt="What were the total sales last quarter?">Total sales last quarter?</button>
                    <button class="agent-suggestion-chip" data-prompt="Who is the manager of the Marketing department?">Marketing department manager?</button>
                    <button class="agent-suggestion-chip" data-prompt="Which product has the highest revenue?">Highest revenue product?</button>
                    <button class="agent-suggestion-chip" data-prompt="How many employees are on leave this month?">Employees on leave this month?</button>
                    <button class="agent-suggestion-chip" data-prompt="Which customers generate the highest freight costs?">Customers with highest freight costs?</button>
                </div>
            </div>
        </div>

        <!-- Input area -->
        <div class="agent-input-area">
            <div class="agent-input-wrapper">
                <input type="text" class="agent-input" id="agentInput" placeholder="Ask about HR, attendance, sales, or revenue..." autocomplete="off" maxlength="500" />
                <button class="agent-send-btn" id="agentSend" disabled>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="22" y1="2" x2="11" y2="13"></line>
                        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                    </svg>
                </button>
            </div>
            <p class="agent-input-hint">Responses are generated by AI and may not be accurate.</p>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<style>
    /* ── Response card ────────────────────────────────────── */
    .agent-response-card {
        background: var(--bg-surface);
        border: 1px solid var(--border-dim);
        border-radius: 14px;
        padding: 1.25rem 1.5rem;
        max-width: 85%;
        animation: fadeInUp 0.35s cubic-bezier(0.22,1,0.36,1) both;
    }
    .agent-response-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 0.75rem;
    }
    .agent-response-title {
        color: var(--text-bright);
        font-weight: 600;
        font-size: 1.05rem;
        margin: 0;
    }
    .agent-response-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
    }
    .agent-meta-chip {
        background: rgba(56,189,248,0.08);
        color: var(--accent);
        font-size: 0.65rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 3px 8px;
        border-radius: 6px;
        border: 1px solid rgba(56,189,248,0.12);
    }
    .agent-response-insight {
        color: var(--text-primary);
        line-height: 1.65;
        font-size: 0.9rem;
        margin-bottom: 0.75rem;
    }
    .agent-response-insight strong { color: var(--text-bright); }
    .agent-chart-container {
        margin-top: 0.75rem;
        background: rgba(6,8,15,0.4);
        border: 1px solid var(--border-dim);
        border-radius: var(--radius-sm);
        padding: 1rem;
    }
    .agent-chart-container canvas {
        max-height: 340px;
    }
    .agent-table-wrapper {
        margin-top: 0.75rem;
        overflow-x: auto;
        border-radius: var(--radius-sm);
        border: 1px solid var(--border-dim);
    }
    .agent-data-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.82rem;
    }
    .agent-data-table th {
        background: rgba(56,189,248,0.06);
        color: var(--accent);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-size: 0.7rem;
        padding: 0.6rem 0.75rem;
        text-align: left;
        border-bottom: 1px solid var(--border-dim);
    }
    .agent-data-table td {
        padding: 0.5rem 0.75rem;
        color: var(--text-primary);
        border-bottom: 1px solid rgba(56,189,248,0.05);
    }
    .agent-data-table tr:hover td {
        background: rgba(56,189,248,0.03);
    }
    .agent-kpi-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 1.5rem;
        margin-top: 0.75rem;
        background: rgba(56,189,248,0.04);
        border: 1px solid var(--border-dim);
        border-radius: var(--radius-sm);
    }
    .agent-kpi-value {
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--accent);
        text-shadow: 0 0 20px rgba(56,189,248,0.3);
    }
    .agent-kpi-label {
        color: var(--text-muted);
        font-size: 0.85rem;
        margin-top: 0.25rem;
    }
</style>
<script>
    const CHART_COLORS = [
        '#38bdf8','#06b6d4','#a78bfa','#f97316',
        '#22c55e','#ef4444','#eab308','#0284c7',
        '#14b8a6','#c084fc','#ec4899','#6ee7b7',
    ];

    const agentMessages    = document.getElementById('agentMessages');
    const agentInput       = document.getElementById('agentInput');
    const agentSend        = document.getElementById('agentSend');
    const agentSuggestions = document.getElementById('agentSuggestions');

    agentInput.addEventListener('input', () => {
        agentSend.disabled = !agentInput.value.trim();
    });
    agentInput.addEventListener('keydown', e => {
        if (e.key === 'Enter' && agentInput.value.trim()) sendAgentMessage(agentInput.value.trim());
    });
    agentSend.addEventListener('click', () => {
        if (agentInput.value.trim()) sendAgentMessage(agentInput.value.trim());
    });

    document.addEventListener('click', e => {
        const chip = e.target.closest('[data-prompt]');
        if (chip && chip.closest('.agent-suggestions')) {
            sendAgentMessage(chip.dataset.prompt);
        }
    });

    function escapeHtml(text) {
        const d = document.createElement('div');
        d.textContent = text;
        return d.innerHTML;
    }

    function stripCitations(text) {
        return text.replace(/\u3010[^\u3011]*\u3011\s*\.?/g, '').replace(/\s{2,}/g, ' ').trim();
    }

    function prettifyChartType(ct) {
        const map = { bar:'Bar chart', horizontalBar:'Horizontal bar', line:'Line chart',
            pie:'Pie chart', doughnut:'Doughnut', table:'Table', kpi:'KPI', stackedBar:'Stacked bar', text:'Text' };
        return map[ct] || 'Visual';
    }

    function addUserMessage(text) {
        const welcome = agentMessages.querySelector('.agent-welcome');
        if (welcome) welcome.style.display = 'none';
        const wrapper = document.createElement('div');
        wrapper.className = 'agent-msg-row agent-msg-row-user';
        const bubble = document.createElement('div');
        bubble.className = 'agent-msg-user';
        bubble.textContent = text;
        wrapper.appendChild(bubble);
        agentMessages.appendChild(wrapper);
        agentMessages.scrollTop = agentMessages.scrollHeight;
    }

    function addResponseCard(data) {
        const welcome = agentMessages.querySelector('.agent-welcome');
        if (welcome) welcome.style.display = 'none';

        const wrapper = document.createElement('div');
        wrapper.className = 'agent-msg-row agent-msg-row-agent';

        const card = document.createElement('div');
        card.className = 'agent-response-card';

        const cleanInsight = stripCitations(data.answer || '');
        const hasChart = data.data && data.data.length && data.chart_type && !['text'].includes(data.chart_type);
        const rowCount = Array.isArray(data.data) ? data.data.length : 0;
        const agentLabel = data.routed_to || 'Agent';

        // Header
        let html = '<div class="agent-response-header">';
        html += `<h4 class="agent-response-title">${escapeHtml(data.title || 'Response')}</h4>`;
        html += '<div class="agent-response-meta">';
        html += `<span class="agent-meta-chip">${escapeHtml(agentLabel)}</span>`;
        if (hasChart) html += `<span class="agent-meta-chip">${prettifyChartType(data.chart_type)}</span>`;
        if (rowCount) html += `<span class="agent-meta-chip">${rowCount} row${rowCount === 1 ? '' : 's'}</span>`;
        html += '</div></div>';

        // Insight text
        html += `<div class="agent-response-insight">${marked.parse(cleanInsight)}</div>`;

        // Visual
        if (hasChart) {
            if (data.chart_type === 'table') {
                html += buildTable(data.data);
            } else if (data.chart_type === 'kpi') {
                html += buildKPI(data);
            } else {
                const cid = 'agent-chart-' + Date.now();
                html += `<div class="agent-chart-container"><canvas id="${cid}"></canvas></div>`;
            }
        }

        card.innerHTML = html;
        wrapper.appendChild(card);
        agentMessages.appendChild(wrapper);
        agentMessages.scrollTop = agentMessages.scrollHeight;

        // Render chart after DOM paint
        if (hasChart && !['table','kpi'].includes(data.chart_type)) {
            const canvas = card.querySelector('canvas');
            if (canvas) requestAnimationFrame(() => renderChart(canvas.id, data));
        }
    }

    function addTextMessage(text, badge) {
        const welcome = agentMessages.querySelector('.agent-welcome');
        if (welcome) welcome.style.display = 'none';
        const wrapper = document.createElement('div');
        wrapper.className = 'agent-msg-row agent-msg-row-agent';
        const bubble = document.createElement('div');
        bubble.className = 'agent-msg-agent';
        const badgeHtml = badge ? `<span class="agent-route-badge">${badge}</span>` : '';
        bubble.innerHTML = badgeHtml + marked.parse(stripCitations(text));
        wrapper.appendChild(bubble);
        agentMessages.appendChild(wrapper);
        agentMessages.scrollTop = agentMessages.scrollHeight;
    }

    /* ── Chart rendering ──────────────────────────────────── */
    function resolveColumn(rows, requested, exclude) {
        if (!rows.length) return requested || null;
        const cols = Object.keys(rows[0]).filter(c => !(exclude || []).includes(c));
        if (!requested) return cols[0] || null;
        if (cols.includes(requested)) return requested;
        const norm = s => String(s||'').toLowerCase().replace(/[^a-z0-9]/g,'');
        const nr = norm(requested);
        return cols.find(c => norm(c) === nr) || cols.find(c => norm(c).includes(nr) || nr.includes(norm(c))) || cols[0] || null;
    }

    function resolveValueCols(rows, requested) {
        const resolved = [];
        for (const r of requested || []) {
            const m = resolveColumn(rows, r, resolved);
            if (m && !resolved.includes(m)) resolved.push(m);
        }
        return resolved;
    }

    function renderChart(canvasId, data) {
        const ctx = document.getElementById(canvasId);
        if (!ctx) return;

        const rows = data.data || [];
        const valCols = resolveValueCols(rows, data.value_columns || []);
        const lblCol = resolveColumn(rows, data.label_column, valCols);
        const isPie = ['pie','doughnut'].includes(data.chart_type);

        if (!lblCol || !valCols.length) return;

        const labels = rows.map(r => r[lblCol]);
        const datasets = valCols.map((col, i) => {
            const ds = {
                label: col,
                data: rows.map(r => r[col]),
                borderWidth: data.chart_type === 'line' ? 2 : 1,
                tension: 0.35,
                fill: false,
            };
            if (isPie) {
                ds.backgroundColor = labels.map((_, j) => CHART_COLORS[j % CHART_COLORS.length]);
                ds.borderColor = 'rgba(6,8,15,0.8)';
                ds.borderWidth = 2;
            } else {
                ds.backgroundColor = CHART_COLORS[i % CHART_COLORS.length] + 'CC';
                ds.borderColor = CHART_COLORS[i % CHART_COLORS.length];
            }
            return ds;
        });

        let type = data.chart_type;
        const opts = {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: { display: isPie || valCols.length > 1, labels: { color: '#94a3b8' } },
                tooltip: { callbacks: { label(c) { return `${c.dataset.label}: ${c.formattedValue}`; } } },
            },
            scales: {
                x: { ticks: { color: '#64748b', autoSkip: true, maxRotation: 45 }, grid: { color: 'rgba(56,189,248,0.06)' } },
                y: { beginAtZero: true, ticks: { color: '#64748b' }, grid: { color: 'rgba(56,189,248,0.06)' } },
            },
        };

        if (type === 'horizontalBar') { type = 'bar'; opts.indexAxis = 'y'; }
        if (type === 'stackedBar') { type = 'bar'; opts.scales = { x:{stacked:true, ticks:{color:'#64748b'}, grid:{color:'rgba(56,189,248,0.06)'}}, y:{stacked:true, ticks:{color:'#64748b'}, grid:{color:'rgba(56,189,248,0.06)'}} }; }
        if (isPie) { delete opts.scales; }

        new Chart(ctx, { type, data: { labels, datasets }, options: opts });
    }

    /* ── Table rendering ──────────────────────────────────── */
    function buildTable(rows) {
        if (!rows || !rows.length) return '<p style="color:var(--text-muted)">No data</p>';
        const cols = Object.keys(rows[0]);
        let h = '<div class="agent-table-wrapper"><table class="agent-data-table"><thead><tr>';
        cols.forEach(c => h += `<th>${escapeHtml(c)}</th>`);
        h += '</tr></thead><tbody>';
        rows.forEach(r => {
            h += '<tr>';
            cols.forEach(c => h += `<td>${escapeHtml(String(r[c] ?? ''))}</td>`);
            h += '</tr>';
        });
        return h + '</tbody></table></div>';
    }

    /* ── KPI rendering ────────────────────────────────────── */
    function buildKPI(data) {
        const row = (data.data && data.data[0]) || {};
        const valCols = data.value_columns || [];
        const val = valCols.length ? (row[valCols[0]] ?? '-') : '-';
        const lbl = data.label_column ? (row[data.label_column] ?? '') : '';
        return `<div class="agent-kpi-card">
            <div class="agent-kpi-value">${escapeHtml(String(val))}</div>
            <div class="agent-kpi-label">${escapeHtml(lbl)}</div>
        </div>`;
    }

    /* ── Typing indicator ─────────────────────────────────── */
    function showTyping() {
        const wrapper = document.createElement('div');
        wrapper.className = 'agent-msg-row agent-msg-row-agent';
        wrapper.id = 'agentTyping';
        wrapper.innerHTML = `<div class="agent-msg-agent agent-typing"><span></span><span></span><span></span></div>`;
        agentMessages.appendChild(wrapper);
        agentMessages.scrollTop = agentMessages.scrollHeight;
    }

    function removeTyping() {
        const el = document.getElementById('agentTyping');
        if (el) el.remove();
    }

    /* ── Send message ─────────────────────────────────────── */
    async function sendAgentMessage(message) {
        addUserMessage(message);
        agentInput.value = '';
        agentSend.disabled = true;
        agentInput.disabled = true;
        showTyping();

        try {
            const res = await fetch('http://localhost:8090/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message })
            });
            const data = await res.json();
            removeTyping();

            if (data.data && data.data.length && data.chart_type) {
                addResponseCard(data);
            } else {
                const badge = data.routed_to ? `Routed to ${data.routed_to}` : null;
                addTextMessage(data.answer, badge);
            }
        } catch (err) {
            removeTyping();
            addTextMessage('Could not reach the agent API. Make sure it is running on port 8090.', null);
        } finally {
            agentInput.disabled = false;
            agentSend.disabled = false;
            agentInput.focus();
        }
    }
</script>
}
